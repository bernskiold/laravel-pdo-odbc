{
  "name": "bernskiold/laravel-snowflake",
  "description": "Snowflake database driver for Laravel, supporting both the native pdo_snowflake extension and ODBC connections.",
  "type": "library",
  "keywords": [
    "laravel",
    "snowflake",
    "database",
    "eloquent",
    "odbc",
    "pdo"
  ],
  "homepage": "https://github.com/bernskiold/laravel-pdo-odbc",
  "license": "MIT",
  "authors": [
    {
      "name": "Bernskiold",
      "email": "erik@bernskiold.com",
      "homepage": "https://bernskiold.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/database": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^10.0|^11.0",
    "pestphp/pest": "^3.8|^4.0",
    "phpstan/phpstan": "^2.2"
  },
  "autoload": {
    "psr-4": {
      "Bernskiold\\LaravelSnowflake\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bernskiold\\LaravelSnowflake\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "lint": "vendor/bin/pint --test",
    "lint:fix": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": [
        "Bernskiold\\LaravelSnowflake\\SnowflakeServiceProvider"
      ]
    }
  }
}
