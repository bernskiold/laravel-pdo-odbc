parameters:
    level: 5
    paths:
        - src
    treatPhpDocTypesAsCertain: false
    universalObjectCratesClasses:
        - Illuminate\Support\Fluent
    ignoreErrors:
        # Fulltext index commands are intentionally skipped (Snowflake has no
        # indexes); returning null makes Blueprint::toSql() omit the statement
        # where the parent grammar would throw instead.
        -
            message: '#Return type \(null\) of method Bernskiold\\LaravelSnowflake\\Grammars\\SchemaGrammar::compile(Fulltext|DropFullText)\(\)#'
            path: src/Grammars/SchemaGrammar.php
